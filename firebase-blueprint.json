{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Ghana Rickshaw Rides app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "role": { "type": "string", "enum": ["user", "driver", "admin"], "description": "The user's role." },
        "subscription": { "type": "string", "enum": ["free", "premium"], "description": "The user's subscription tier." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created." }
      },
      "required": ["uid", "email", "role", "subscription", "createdAt"]
    },
    "Ride": {
      "title": "Ride",
      "description": "A ride booking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who booked the ride." },
        "driverId": { "type": "string", "description": "The ID of the driver." },
        "pickupAddress": { "type": "string", "description": "The pickup address." },
        "pickupLat": { "type": "number", "description": "Pickup latitude." },
        "pickupLng": { "type": "number", "description": "Pickup longitude." },
        "dropoffAddress": { "type": "string", "description": "The dropoff address." },
        "dropoffLat": { "type": "number", "description": "Dropoff latitude." },
        "dropoffLng": { "type": "number", "description": "Dropoff longitude." },
        "status": { "type": "string", "enum": ["pending", "accepted", "in-progress", "completed", "cancelled"], "description": "The ride status." },
        "fare": { "type": "number", "description": "The estimated or final fare." },
        "scheduledTime": { "type": "string", "format": "date-time", "description": "When the ride is scheduled for." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the ride was booked." },
        "rating": { "type": "number", "description": "Driver rating for the ride." },
        "review": { "type": "string", "description": "Review text." },
        "refundStatus": { "type": "string", "enum": ["none", "requested", "processed", "rejected"], "description": "Refund status." },
        "rideType": { "type": "string", "enum": ["private", "shared"], "description": "Type of ride." }
      },
      "required": ["userId", "pickupAddress", "pickupLat", "pickupLng", "dropoffAddress", "dropoffLat", "dropoffLng", "status", "createdAt", "rideType"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/rides/{rideId}": {
      "schema": { "$ref": "#/entities/Ride" },
      "description": "Stores ride bookings."
    }
  }
}
